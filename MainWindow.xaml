<Window x:Class="Trackify.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trackify"
        Height="150"
        Width="380"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        Loaded="Window_Loaded">

    <Window.Resources>

        <!-- Fluent Buttons -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#40FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- MAIN CARD -->
    <Border x:Name="RootBorder"
            CornerRadius="20"
            Background="#DD1C1C1C"
            BorderBrush="#22FFFFFF"
            BorderThickness="1"
            Padding="14"
            Opacity="0.98"
            MouseEnter="Root_MouseEnter"
            MouseLeave="Root_MouseLeave">

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Album Art -->
            <Border Width="80"
                    Height="80"
                    CornerRadius="16"
                    ClipToBounds="True"
                    VerticalAlignment="Center">

                <Image x:Name="AlbumArt"
                       Stretch="UniformToFill"/>
            </Border>

            <!-- Right Side -->
            <Grid Grid.Column="1"
                  Margin="14,0,0,0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Song -->
                <TextBlock x:Name="SongTitle"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="White"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Artist -->
                <TextBlock x:Name="ArtistName"
                           Grid.Row="1"
                           FontSize="13"
                           Foreground="#BFBFBF"
                           Margin="0,3,0,0"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Genre -->
                <Border Grid.Row="2"
                        Background="#3320C997"
                        CornerRadius="10"
                        HorizontalAlignment="Left"
                        Margin="0,6,0,0"
                        Padding="10,4">

                    <TextBlock x:Name="GenreText"
                               FontSize="11"
                               Foreground="#CFFCF4"/>
                </Border>

                <!-- Controls -->
                <StackPanel x:Name="ControlPanel"
                            Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0"
                            Opacity="0">

                    <Button Width="34" Height="34"
                            Content="⏮"
                            Margin="0,0,6,0"
                            Click="PrevButton_Click"/>

                    <Button Width="34" Height="34"
                            Content="⏯"
                            Margin="0,0,6,0"
                            Click="PauseButton_Click"/>

                    <Button Width="34" Height="34"
                            Content="⏭"
                            Click="NextButton_Click"/>

                </StackPanel>

            </Grid>

        </Grid>

    </Border>

</Window>